# ============================================
# Environment Variables - Gym Expert System
# ============================================
# Salin file ini menjadi .env untuk development lokal
#   copy .env.example .env
#
# Untuk production di Netlify:
# Set variabel SUPABASE_URL, SUPABASE_SERVICE_KEY, JWT_SECRET saja.
# VITE_API_URL TIDAK PERLU diisi — otomatis pakai /api (relative path)

# === SUPABASE (wajib) ===
# URL project Supabase kamu (dapatkan dari Supabase Dashboard > Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# Service Role Key (dapatkan dari Supabase Dashboard > Settings > API > service_role key)
# JANGAN pernah expose key ini ke frontend!
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# === JWT SECRET ===
# Secret key untuk menandatangani token JWT (ganti dengan string random yang aman)
JWT_SECRET=ubah-ini-dengan-string-random-yang-aman

# === CORS (hanya untuk development lokal) ===
# Domain yang diizinkan (pisahkan dengan koma jika lebih dari satu)
CORS_ORIGIN=http://localhost:5173

# === VITE (opsional) ===
# Untuk development lokal: http://localhost:4000/api (dengan proxy Vite)
# Di NETLIFY: TIDAK PERLU diisi! Frontend otomatis pakai /api
# VITE_API_URL=http://localhost:4000/api
