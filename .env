# ============================================================
# Environment Variables - Gym Expert System
# ============================================================
# File ini untuk LOCAL DEVELOPMENT saja.
#
# Untuk deploy ke NETLIFY, set variabel berikut di:
#   Netlify Dashboard → Site → Environment variables
#
# Yang WAJIB diset di Netlify Dashboard:
#   SUPABASE_URL
#   SUPABASE_SERVICE_KEY
#   JWT_SECRET
#
# Yang TIDAK PERLU diset di Netlify:
#   PORT         → Tidak dipakai oleh Netlify Functions
#   CORS_ORIGIN  → Netlify Functions sudah handle CORS (origin: true)
#   VITE_API_URL → JANGAN diset! Biarkan fallback ke /api (same-origin)
# ============================================================

# === SUPABASE (wajib — isi di Netlify Dashboard juga) ===
SUPABASE_URL=https://mwdjcfpwzkznggwgxodi.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im13ZGpjZnB3emt6bmdnd2d4b2RpIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MDkxMjk5NiwiZXhwIjoyMDk2NDg4OTk2fQ.HQO9fjygI_ltWbYJJG_iZTJIZBTEdsG1rR-tTm5VLRw

# === JWT SECRET (wajib — ganti dengan string random yang kuat!) ===
JWT_SECRET=verysecretkey

# === LOCAL DEVELOPMENT ONLY (jangan diset di Netlify) ===
PORT=4000
CORS_ORIGIN=http://localhost:5173

